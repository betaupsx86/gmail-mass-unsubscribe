{
  "manifest_version": 3,
  "name": "Gmail Mass Unsubscribe",
  "version": "1.1",
  "description": "Mass unsubscribe from Gmail promotions, updates, and any search with one click.",

  "oauth2": {
    "client_id": "396260624027-3bcefdsge0kssjcslc4qmicldoocahij.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.modify"]
  },

  "permissions": ["identity", "storage", "tabs"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://www.googleapis.com/*",
    "https://*/*",
    "http://*/*"
  ],

  "background": { "service_worker": "background.js" },

  "content_scripts": [{
    "matches": ["https://mail.google.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
